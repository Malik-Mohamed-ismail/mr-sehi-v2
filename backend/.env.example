# ── DATABASE ──
DATABASE_URL=postgresql://user:password@localhost:5432/mr_sehi_db
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/mr_sehi_test
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── AUTH ──
JWT_SECRET=mr-sehi-super-secret-jwt-key-2026-change-this-in-production-minimum-64-chars-okay
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
COOKIE_SECRET=mr-sehi-cookie-secret-2026-change-in-production

# ── APP ──
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
API_VERSION=v1

# ── LOGGING ──
LOG_LEVEL=info
LOG_FORMAT=pretty

# ── PDF ──
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ── RATE LIMITS ──
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_API_MAX=200
RATE_LIMIT_REPORT_MAX=10

# ── BUSINESS RULES ──
VAT_RATE=0.15
SAR_CURRENCY_CODE=SAR
CRON_TIMEZONE=Asia/Riyadh
